pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                    mvn sonar:sonar \
                    -Dsonar.projectKey=my-project \
                    -Dsonar.login=sqa_c01a28736407db685c5a10ca982160c7859b8afb
                    '''
                }
            }
        }
    }
}
