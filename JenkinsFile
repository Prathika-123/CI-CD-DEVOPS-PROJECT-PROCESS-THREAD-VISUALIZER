pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK'
    }

    stages {

        stage('Build') {
            steps {
                sh 'mvn clean install'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Deploy Local') {
            steps {
                sh 'nohup java -jar target/PTV-0.0.1-SNAPSHOT.jar --server.address=0.0.0.0 > app.log 2>&1 &'
            }
        }
    }
}
